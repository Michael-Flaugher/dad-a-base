---
// DADABASE — Dad Joke Generator
// Jokes pulled live from icanhazdadjoke.com
// deploy to jokes.michaelflaugher.com
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>DADABASE</title>

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323:wght@400&display=swap" rel="stylesheet" />

	<style>
		/* == RESET == */
		* { margin: 0; padding: 0; box-sizing: border-box; }

		/* == CSS VARS == */
		:root {
			--neon-cyan:    #00ffff;
			--neon-magenta: #ff00e6;
			--neon-yellow:  #ffee00;
			--neon-green:   #00ff88;
			--neon-red:     #ff2a6d;
			--cabinet:      #0a0a0a;
			--cabinet-edge: #1a1a1a;
			--screen-bg:    #020810;
		}

		html, body {
			height: 100%;
			background: #000;
			color: #fff;
			font-family: 'VT323', monospace;
			overflow-x: hidden;
		}

		/* == SCANLINE OVERLAY — gives CRT feel across the whole page == */
		body::before {
			content: '';
			position: fixed;
			inset: 0;
			background: repeating-linear-gradient(
				0deg,
				transparent,
				transparent 2px,
				rgba(0,0,0,0.18) 2px,
				rgba(0,0,0,0.18) 4px
			);
			pointer-events: none;
			z-index: 1000;
		}

		/* == BACKGROUND — grid of dots, subtle neon glow == */
		body {
			background:
				radial-gradient(ellipse at 20% 50%, rgba(0,255,255,0.04) 0%, transparent 60%),
				radial-gradient(ellipse at 80% 50%, rgba(255,0,230,0.04) 0%, transparent 60%),
				radial-gradient(circle at 50% 0%, rgba(255,238,0,0.03) 0%, transparent 50%),
				#000;
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 24px;
			gap: 0;
		}

		/* == PAGE TITLE == */
		.page-title {
			font-family: 'Press Start 2P', monospace;
			font-size: clamp(1.4rem, 4vw, 2.2rem);
			color: var(--neon-yellow);
			text-shadow:
				0 0 10px var(--neon-yellow),
				0 0 30px var(--neon-yellow),
				0 0 60px rgba(255,238,0,0.4);
			letter-spacing: 0.08em;
			margin-bottom: 6px;
			animation: titleFlicker 6s infinite;
		}

		.page-subtitle {
			font-family: 'VT323', monospace;
			font-size: 1.3rem;
			color: var(--neon-cyan);
			text-shadow: 0 0 8px var(--neon-cyan);
			letter-spacing: 0.3em;
			margin-bottom: 32px;
			opacity: 0.8;
		}

		@keyframes titleFlicker {
			0%, 95%, 100% { opacity: 1; }
			96%            { opacity: 0.85; }
			97%            { opacity: 1; }
			98%            { opacity: 0.7; }
			99%            { opacity: 1; }
		}

		/* == CABINET WRAPPER — holds machine + handle side by side == */
		.cabinet-wrapper {
			display: flex;
			align-items: center;
			gap: 0;
		}

		/* == SLOT MACHINE CABINET == */
		.cabinet {
			background: linear-gradient(180deg, #111 0%, #0a0a0a 100%);
			border: 3px solid #222;
			border-radius: 20px 20px 12px 12px;
			padding: 28px 28px 32px;
			width: clamp(320px, 55vw, 520px);
			position: relative;
			box-shadow:
				0 0 0 1px #333,
				inset 0 1px 0 #2a2a2a,
				0 20px 60px rgba(0,0,0,0.8);
		}

		/* Neon edge strips on cabinet sides */
		.cabinet::before,
		.cabinet::after {
			content: '';
			position: absolute;
			top: 20px;
			bottom: 20px;
			width: 3px;
			border-radius: 3px;
		}
		.cabinet::before {
			left: 8px;
			background: var(--neon-cyan);
			box-shadow: 0 0 8px var(--neon-cyan), 0 0 20px rgba(0,255,255,0.3);
			animation: edgeFlicker 4s infinite;
		}
		.cabinet::after {
			right: 8px;
			background: var(--neon-magenta);
			box-shadow: 0 0 8px var(--neon-magenta), 0 0 20px rgba(255,0,230,0.3);
			animation: edgeFlicker 4s 0.5s infinite;
		}

		@keyframes edgeFlicker {
			0%, 90%, 100% { opacity: 1; }
			91%            { opacity: 0.6; }
			92%            { opacity: 1; }
			93%            { opacity: 0.4; }
			94%            { opacity: 1; }
		}

		/* == SCREEN BEZEL == */
		.screen-bezel {
			background: #050505;
			border: 3px solid #1a1a1a;
			border-radius: 10px;
			padding: 6px;
			margin-bottom: 24px;
			box-shadow:
				0 0 0 1px #0a0a0a,
				inset 0 0 20px rgba(0,0,0,0.8);
			position: relative;
		}

		/* Neon glow around screen */
		.screen-bezel::before {
			content: '';
			position: absolute;
			inset: -4px;
			border-radius: 13px;
			background: transparent;
			box-shadow:
				0 0 12px rgba(0,255,255,0.25),
				0 0 30px rgba(0,255,255,0.1),
				inset 0 0 12px rgba(0,255,255,0.05);
			pointer-events: none;
		}

		/* == SCREEN == */
		.screen {
			background: var(--screen-bg);
			border-radius: 7px;
			min-height: 180px;
			display: flex;
			align-items: center;
			justify-content: center;
			padding: 24px 20px;
			position: relative;
			overflow: hidden;
		}

		/* CRT phosphor glow effect */
		.screen::after {
			content: '';
			position: absolute;
			inset: 0;
			background: radial-gradient(ellipse at 50% 30%, rgba(0,255,136,0.04) 0%, transparent 70%);
			pointer-events: none;
		}

		/* == JOKE TEXT — slot reel window == */
		.joke-reel {
			position: relative;
			width: 100%;
			overflow: hidden;
			height: 140px;
			display: flex;
			align-items: center;
			justify-content: center;
		}

		.joke-text {
			font-family: 'VT323', monospace;
			font-size: clamp(1.3rem, 3vw, 1.7rem);
			color: var(--neon-green);
			text-shadow: 0 0 8px var(--neon-green), 0 0 20px rgba(0,255,136,0.3);
			text-align: center;
			line-height: 1.5;
			width: 100%;
			transition: none;
		}

		/* Idle blinking cursor state */
		.joke-text.idle::after {
			content: '█';
			animation: blink 1s step-end infinite;
			color: var(--neon-green);
		}

		@keyframes blink {
			0%, 100% { opacity: 1; }
			50%       { opacity: 0; }
		}

		/* Spinning — text scrambles fast */
		.joke-text.spinning {
			color: var(--neon-yellow);
			text-shadow: 0 0 8px var(--neon-yellow), 0 0 20px rgba(255,238,0,0.4);
		}

		/* Result — bright white then settles green */
		.joke-text.result {
			animation: resultReveal 0.4s ease forwards;
		}

		@keyframes resultReveal {
			0%   { color: #fff; text-shadow: 0 0 20px #fff, 0 0 40px var(--neon-cyan); }
			100% { color: var(--neon-green); text-shadow: 0 0 8px var(--neon-green); }
		}

		/* == REEL EDGE LINES — top and bottom of slot window == */
		.reel-edge {
			position: absolute;
			left: 0; right: 0;
			height: 2px;
			background: var(--neon-cyan);
			box-shadow: 0 0 6px var(--neon-cyan);
			z-index: 10;
		}
		.reel-edge.top    { top: 0; }
		.reel-edge.bottom { bottom: 0; }

		/* == COIN COUNTER / STATUS BAR == */
		.status-bar {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 20px;
			padding: 0 4px;
		}

		.status-label {
			font-family: 'Press Start 2P', monospace;
			font-size: 0.5rem;
			color: #444;
			letter-spacing: 0.1em;
		}

		.pull-count {
			font-family: 'Press Start 2P', monospace;
			font-size: 0.55rem;
			color: var(--neon-magenta);
			text-shadow: 0 0 6px var(--neon-magenta);
			letter-spacing: 0.08em;
		}

		/* == BUTTON ROW — removed, handle only == */

		/* == HANDLE ASSEMBLY — right side of cabinet == */
		.handle-assembly {
			display: flex;
			flex-direction: column;
			align-items: center;
			cursor: pointer;
			user-select: none;
			margin-left: -2px;
			padding: 20px 0;
			position: relative;
		}

		/* Mount bracket at the TOP — this is the fixed pivot point */
		.handle-mount {
			width: 28px;
			height: 22px;
			background: #2a2a2a;
			border: 2px solid #444;
			border-radius: 5px;
			box-shadow: 0 2px 8px rgba(0,0,0,0.7), inset 0 1px 2px rgba(255,255,255,0.05);
			flex-shrink: 0;
			z-index: 2;
		}

		/* Swinging part — arm + ball hang from the mount and rotate from top */
		.handle-swing {
			display: flex;
			flex-direction: column;
			align-items: center;
			transform-origin: top center;  /* pivot at the mount connection */
		}

		/* Arm hangs down from mount */
		.handle-arm {
			width: 12px;
			height: 120px;
			background: linear-gradient(90deg, #252525, #484848, #252525);
			border-radius: 0 0 6px 6px;
			box-shadow: 2px 0 8px rgba(0,0,0,0.6), inset 1px 0 2px rgba(255,255,255,0.05);
			flex-shrink: 0;
		}

		/* Ball at the BOTTOM of the arm */
		.handle-ball {
			width: 36px;
			height: 36px;
			border-radius: 50%;
			background: radial-gradient(circle at 35% 35%, #ff6688, var(--neon-red));
			box-shadow:
				0 0 12px var(--neon-red),
				0 0 30px rgba(255,42,109,0.4),
				inset 0 -3px 6px rgba(0,0,0,0.4);
			flex-shrink: 0;
		}

		/* PULL — whole swing group rotates around the mount pivot */
		.handle-assembly.pulling .handle-swing {
			animation: handlePull 0.55s cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
		}

		@keyframes handlePull {
			0%   { transform: rotate(0deg); }
			35%  { transform: rotate(38deg); }
			65%  { transform: rotate(32deg); }
			100% { transform: rotate(0deg); }
		}

		/* Label under handle */
		.handle-label {
			font-family: 'Press Start 2P', monospace;
			font-size: 0.35rem;
			color: #333;
			letter-spacing: 0.15em;
			margin-top: 10px;
			writing-mode: vertical-rl;
			transform: rotate(180deg);
		}

		/* == DECORATIVE PIXEL LIGHTS top of cabinet == */
		.pixel-lights {
			display: flex;
			justify-content: center;
			gap: 8px;
			margin-bottom: 20px;
		}

		.pixel-light {
			width: 8px;
			height: 8px;
			border-radius: 2px;
		}

		.pixel-light:nth-child(1) { background: var(--neon-red);     box-shadow: 0 0 6px var(--neon-red);     animation: lightSeq 1.2s 0.0s infinite; }
		.pixel-light:nth-child(2) { background: var(--neon-yellow);  box-shadow: 0 0 6px var(--neon-yellow);  animation: lightSeq 1.2s 0.2s infinite; }
		.pixel-light:nth-child(3) { background: var(--neon-green);   box-shadow: 0 0 6px var(--neon-green);   animation: lightSeq 1.2s 0.4s infinite; }
		.pixel-light:nth-child(4) { background: var(--neon-cyan);    box-shadow: 0 0 6px var(--neon-cyan);    animation: lightSeq 1.2s 0.6s infinite; }
		.pixel-light:nth-child(5) { background: var(--neon-magenta); box-shadow: 0 0 6px var(--neon-magenta); animation: lightSeq 1.2s 0.8s infinite; }
		.pixel-light:nth-child(6) { background: var(--neon-red);     box-shadow: 0 0 6px var(--neon-red);     animation: lightSeq 1.2s 1.0s infinite; }

		@keyframes lightSeq {
			0%, 40%, 100% { opacity: 1; }
			20%            { opacity: 0.15; }
		}

		/* == FOOTER == */
		.page-footer {
			margin-top: 28px;
			font-family: 'Press Start 2P', monospace;
			font-size: 0.38rem;
			color: #2a2a2a;
			letter-spacing: 0.12em;
			text-align: center;
		}

		/* == MOBILE — stack handle below on small screens == */
		@media (max-width: 520px) {
			.cabinet-wrapper { flex-direction: column; }
			.handle-assembly {
				flex-direction: row;
				margin-left: 0;
				margin-top: -2px;
				padding: 0 20px;
				transform: rotate(90deg) scaleX(-1);
			}
			.handle-label { display: none; }
		}
	</style>
</head>

<body>

	<h1 class="page-title">DADABASE</h1>
	<p class="page-subtitle">▸ DAD JOKE GENERATOR ◂</p>

	<div class="cabinet-wrapper">

		<!-- == SLOT MACHINE CABINET == -->
		<div class="cabinet">

			<!-- Pixel lights across the top -->
			<div class="pixel-lights">
				<div class="pixel-light"></div>
				<div class="pixel-light"></div>
				<div class="pixel-light"></div>
				<div class="pixel-light"></div>
				<div class="pixel-light"></div>
				<div class="pixel-light"></div>
			</div>

			<!-- Screen -->
			<div class="screen-bezel">
				<div class="screen">
					<div class="reel-edge top"></div>
					<div class="joke-reel">
						<div class="joke-text idle" id="joke-text">
							PULL THE HANDLE
						</div>
					</div>
					<div class="reel-edge bottom"></div>
				</div>
			</div>

			<!-- Status bar -->
			<div class="status-bar">
				<span class="status-label">DADABASE v1.0</span>
				<span class="pull-count" id="pull-count">PULLS: 000</span>
			</div>

		</div>

		<!-- == HANDLE — mount at top is the pivot, arm+ball swing down == -->
		<div class="handle-assembly" id="handle" onclick="doPull()">
			<div class="handle-mount"></div>
			<div class="handle-swing">
				<div class="handle-arm"></div>
				<div class="handle-ball"></div>
			</div>
			<span class="handle-label">PULL</span>
		</div>

	</div>

	<p class="page-footer">michaelflaugher.com &nbsp;·&nbsp; JOKES BY ICANHAZDADJOKE.COM</p>

	<script is:inline>

		// == STATE ==
		let isSpinning = false;
		let pullCount  = 0;
		let spinInterval = null;

		// Scramble characters used during spin animation
		const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%?*&░▒▓█▄▀■□▪▫';

		// == PULL ==
		async function doPull() {
			if (isSpinning) return;
			isSpinning = true;

			const jokeEl = document.getElementById('joke-text');
			const handle = document.getElementById('handle');

			// Trigger handle animation
			handle.classList.add('pulling');
			setTimeout(() => handle.classList.remove('pulling'), 600);

			// Update pull counter
			pullCount++;
			document.getElementById('pull-count').textContent =
				'PULLS: ' + String(pullCount).padStart(3, '0');

			// Start screen spinning — scramble text fast
			jokeEl.className = 'joke-text spinning';
			jokeEl.textContent = scramble(16);

			let spinSpeed = 60;  // ms between scramble updates — starts fast
			let elapsed   = 0;
			const TOTAL_SPIN = 1800; // total spin duration ms

			// Spin loop — gradually slows down
			spinInterval = setInterval(() => {
				elapsed += spinSpeed;
				jokeEl.textContent = scramble(Math.floor(8 + (elapsed / TOTAL_SPIN) * 20));

				// Slow down over time
				if (elapsed > TOTAL_SPIN * 0.5) spinSpeed = 120;
				if (elapsed > TOTAL_SPIN * 0.75) spinSpeed = 200;

				if (elapsed >= TOTAL_SPIN) {
					clearInterval(spinInterval);
					fetchJoke();
				}
			}, spinSpeed);
		}

		// == SCRAMBLE — returns a string of random arcade characters ==
		function scramble(length) {
			let out = '';
			for (let i = 0; i < length; i++) {
				if (Math.random() > 0.7) out += ' ';
				else out += CHARS[Math.floor(Math.random() * CHARS.length)];
			}
			return out;
		}

		// == FETCH JOKE from icanhazdadjoke.com ==
		async function fetchJoke() {
			const jokeEl     = document.getElementById('joke-text');
			const pullBtn    = document.getElementById('pull-btn');
			const anotherBtn = document.getElementById('another-btn');

			try {
				const res  = await fetch('https://icanhazdadjoke.com/', {
					headers: { 'Accept': 'application/json' }
				});
				const data = await res.json();

				// Reveal joke with flash effect
				jokeEl.className = 'joke-text result';
				jokeEl.textContent = data.joke;

				// After animation settles, go back to green idle
				setTimeout(() => {
					jokeEl.className = 'joke-text';
				}, 400);

			} catch (err) {
				jokeEl.className   = 'joke-text';
				jokeEl.textContent = 'ERROR: DAD JOKES UNAVAILABLE. CHECK YOUR WI-FI, SON.';
			}

			// Re-enable handle
			isSpinning = false;
		}

	</script>

</body>
</html>

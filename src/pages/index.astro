---
// DADABASE — Dad Joke Generator
// Jokes pulled live from icanhazdadjoke.com
// deploy to dad-a-base.michaelflaugher.com
---

<html lang="en">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1" />
	<title>DADABASE</title>

	<link rel="preconnect" href="https://fonts.googleapis.com" />
	<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
	<link href="https://fonts.googleapis.com/css2?family=Press+Start+2P&family=VT323:wght@400&display=swap" rel="stylesheet" />

	<style>
		/* == RESET == */
		* { margin: 0; padding: 0; box-sizing: border-box; }

		:root {
			--neon-cyan:    #00ffff;
			--neon-magenta: #ff00e6;
			--neon-yellow:  #ffee00;
			--neon-green:   #00ff88;
			--neon-red:     #ff2a6d;
			--screen-bg:    #020810;
		}

		html, body {
			height: 100%;
			background: #000;
			color: #fff;
			font-family: 'VT323', monospace;
			overflow-x: hidden;
		}

		/* CRT scanlines */
		body::before {
			content: '';
			position: fixed;
			inset: 0;
			background: repeating-linear-gradient(
				0deg,
				transparent,
				transparent 2px,
				rgba(0,0,0,0.18) 2px,
				rgba(0,0,0,0.18) 4px
			);
			pointer-events: none;
			z-index: 1000;
		}

		body {
			background:
				radial-gradient(ellipse at 20% 50%, rgba(0,255,255,0.04) 0%, transparent 60%),
				radial-gradient(ellipse at 80% 50%, rgba(255,0,230,0.04) 0%, transparent 60%),
				radial-gradient(circle at 50% 0%, rgba(255,238,0,0.03) 0%, transparent 50%),
				#000;
			min-height: 100vh;
			display: flex;
			flex-direction: column;
			align-items: center;
			justify-content: center;
			padding: 24px;
		}

		.page-title {
			font-family: 'Press Start 2P', monospace;
			font-size: clamp(1.4rem, 4vw, 2.2rem);
			color: var(--neon-yellow);
			text-shadow: 0 0 10px var(--neon-yellow), 0 0 30px var(--neon-yellow), 0 0 60px rgba(255,238,0,0.4);
			letter-spacing: 0.08em;
			margin-bottom: 6px;
			animation: titleFlicker 6s infinite;
		}

		.page-subtitle {
			font-family: 'VT323', monospace;
			font-size: 1.3rem;
			color: var(--neon-cyan);
			text-shadow: 0 0 8px var(--neon-cyan);
			letter-spacing: 0.3em;
			margin-bottom: 32px;
			opacity: 0.8;
		}

		@keyframes titleFlicker {
			0%, 95%, 100% { opacity: 1; }
			96% { opacity: 0.85; } 97% { opacity: 1; }
			98% { opacity: 0.7;  } 99% { opacity: 1; }
		}

		/* == CABINET == */
		.cabinet {
			background: linear-gradient(180deg, #111 0%, #0a0a0a 100%);
			border: 3px solid #222;
			border-radius: 20px 20px 12px 12px;
			padding: 28px 28px 32px;
			width: clamp(320px, 55vw, 520px);
			position: relative;
			box-shadow: 0 0 0 1px #333, inset 0 1px 0 #2a2a2a, 0 20px 60px rgba(0,0,0,0.8);
		}

		.cabinet::before, .cabinet::after {
			content: '';
			position: absolute;
			top: 20px; bottom: 20px;
			width: 3px;
			border-radius: 3px;
		}
		.cabinet::before {
			left: 8px;
			background: var(--neon-cyan);
			box-shadow: 0 0 8px var(--neon-cyan), 0 0 20px rgba(0,255,255,0.3);
			animation: edgeFlicker 4s infinite;
		}
		.cabinet::after {
			right: 8px;
			background: var(--neon-magenta);
			box-shadow: 0 0 8px var(--neon-magenta), 0 0 20px rgba(255,0,230,0.3);
			animation: edgeFlicker 4s 0.5s infinite;
		}

		@keyframes edgeFlicker {
			0%, 90%, 100% { opacity: 1; }
			91% { opacity: 0.6; } 92% { opacity: 1; }
			93% { opacity: 0.4; } 94% { opacity: 1; }
		}

		/* == SCREEN == */
		.screen-bezel {
			background: #050505;
			border: 3px solid #1a1a1a;
			border-radius: 10px;
			padding: 6px;
			margin-bottom: 28px;
			box-shadow: 0 0 0 1px #0a0a0a, inset 0 0 20px rgba(0,0,0,0.8);
			position: relative;
		}
		.screen-bezel::before {
			content: '';
			position: absolute;
			inset: -4px;
			border-radius: 13px;
			box-shadow: 0 0 12px rgba(0,255,255,0.25), 0 0 30px rgba(0,255,255,0.1);
			pointer-events: none;
		}
		.screen {
			background: var(--screen-bg);
			border-radius: 7px;
			min-height: 260px;
			display: flex;
			align-items: flex-start;
			justify-content: center;
			padding: 32px 24px;
			position: relative;
			overflow: visible;
		}
		.screen::after {
			content: '';
			position: absolute;
			inset: 0;
			background: radial-gradient(ellipse at 50% 30%, rgba(0,255,136,0.04) 0%, transparent 70%);
			pointer-events: none;
		}
		.joke-reel {
			position: relative;
			width: 100%;
			max-height: 200px;
			overflow-y: auto;
			display: flex;
			align-items: center;
			justify-content: center;
			scrollbar-width: thin;
			scrollbar-color: #444 transparent;
		}
		.joke-reel::-webkit-scrollbar { width: 4px; }
		.joke-reel::-webkit-scrollbar-track { background: transparent; }
		.joke-reel::-webkit-scrollbar-thumb { background: #444; border-radius: 2px; }
		.joke-text {
			font-family: 'VT323', monospace;
			font-size: clamp(1.4rem, 3.1vw, 1.8rem);
			color: var(--neon-green);
			text-shadow: 0 0 8px var(--neon-green), 0 0 20px rgba(0,255,136,0.3);
			text-align: center;
			line-height: 1.6;
			width: 100%;
		}
		.joke-text.idle::after {
			content: '█';
			animation: blink 1s step-end infinite;
			color: var(--neon-green);
		}
		@keyframes blink { 0%, 100% { opacity: 1; } 50% { opacity: 0; } }
		.joke-text.spinning {
			color: var(--neon-yellow);
			text-shadow: 0 0 8px var(--neon-yellow), 0 0 20px rgba(255,238,0,0.4);
		}
		.joke-text.result { animation: resultReveal 0.4s ease forwards; }
		@keyframes resultReveal {
			0%   { color: #fff; text-shadow: 0 0 20px #fff, 0 0 40px var(--neon-cyan); }
			100% { color: var(--neon-green); text-shadow: 0 0 8px var(--neon-green); }
		}
		.reel-edge {
			position: absolute; left: 0; right: 0;
			height: 2px;
			background: var(--neon-cyan);
			box-shadow: 0 0 6px var(--neon-cyan);
			z-index: 10;
		}
		.reel-edge.top { top: 0; } .reel-edge.bottom { bottom: 0; }

		/* == STATUS BAR == */
		.status-bar {
			display: flex;
			justify-content: space-between;
			align-items: center;
			margin-bottom: 28px;
			padding: 0 4px;
		}
		.status-label {
			font-family: 'Press Start 2P', monospace;
			font-size: 0.5rem;
			color: #444;
			letter-spacing: 0.1em;
		}
		.pull-count {
			font-family: 'Press Start 2P', monospace;
			font-size: 0.55rem;
			color: var(--neon-magenta);
			text-shadow: 0 0 6px var(--neon-magenta);
			letter-spacing: 0.08em;
		}

		/* == ARCADE BUTTON PANEL == */
		.button-panel {
			display: flex;
			align-items: center;
			justify-content: center;
			gap: 28px;
			background: #0a0a0a;
			border: 2px solid #1e1e1e;
			border-radius: 10px;
			padding: 24px 28px;
		}

		.arcade-btn-wrap {
			display: flex;
			flex-direction: column;
			align-items: center;
			cursor: pointer;
			user-select: none;
		}

		/* Flat 2D tile button */
		.arcade-btn-inner {
			width: 100px;
			height: 52px;
			border-radius: 6px;
			background: var(--neon-red);
			border: 2px solid #ff6688;
			box-shadow:
				0 0 12px rgba(255,42,109,0.5),
				0 0 30px rgba(255,42,109,0.2);
			display: flex;
			align-items: center;
			justify-content: center;
			font-family: 'Press Start 2P', monospace;
			font-size: 0.5rem;
			color: #fff;
			letter-spacing: 0.1em;
			text-shadow: 0 0 6px rgba(255,255,255,0.6);
			transition: all 0.08s ease;
			animation: btnGlow 2.5s ease-in-out infinite;
		}

		@keyframes btnGlow {
			0%, 100% { box-shadow: 0 0 8px rgba(255,42,109,0.3), 0 0 18px rgba(255,42,109,0.1); }
			50%       { box-shadow: 0 0 14px rgba(255,42,109,0.5), 0 0 28px rgba(255,42,109,0.2); }
		}

		.arcade-btn-wrap:active .arcade-btn-inner,
		.arcade-btn-wrap.pressed .arcade-btn-inner {
			background: #ff6688;
			box-shadow: 0 0 18px rgba(255,42,109,0.7), 0 0 36px rgba(255,42,109,0.3);
			animation: none;
		}

		.btn-label {
			font-family: 'Press Start 2P', monospace;
			font-size: 0.4rem;
			color: #333;
			letter-spacing: 0.15em;
			margin-top: 10px;
		}

		/* == PIXEL LIGHTS == */
		.pixel-lights {
			display: flex;
			justify-content: center;
			gap: 8px;
			margin-bottom: 20px;
		}
		.pixel-light { width: 8px; height: 8px; border-radius: 2px; }
		.pixel-light:nth-child(1) { background: var(--neon-red);     box-shadow: 0 0 6px var(--neon-red);     animation: lightSeq 1.2s 0.0s infinite; }
		.pixel-light:nth-child(2) { background: var(--neon-yellow);  box-shadow: 0 0 6px var(--neon-yellow);  animation: lightSeq 1.2s 0.2s infinite; }
		.pixel-light:nth-child(3) { background: var(--neon-green);   box-shadow: 0 0 6px var(--neon-green);   animation: lightSeq 1.2s 0.4s infinite; }
		.pixel-light:nth-child(4) { background: var(--neon-cyan);    box-shadow: 0 0 6px var(--neon-cyan);    animation: lightSeq 1.2s 0.6s infinite; }
		.pixel-light:nth-child(5) { background: var(--neon-magenta); box-shadow: 0 0 6px var(--neon-magenta); animation: lightSeq 1.2s 0.8s infinite; }
		.pixel-light:nth-child(6) { background: var(--neon-red);     box-shadow: 0 0 6px var(--neon-red);     animation: lightSeq 1.2s 1.0s infinite; }
		@keyframes lightSeq { 0%, 40%, 100% { opacity: 1; } 20% { opacity: 0.15; } }

		/* == FOOTER == */
		.page-footer {
			margin-top: 28px;
			font-family: 'Press Start 2P', monospace;
			font-size: 0.38rem;
			color: #2a2a2a;
			letter-spacing: 0.12em;
			text-align: center;
		}

		@media (max-width: 480px) {
			.button-panel { padding: 16px 20px; gap: 20px; }
			.arcade-btn-outer { width: 68px; height: 68px; }
			.arcade-btn-inner { width: 52px; height: 52px; }
		}
	</style>
</head>

<body>

	<h1 class="page-title">DAD-A-BASE</h1>
	<p class="page-subtitle">▸ DAD JOKE GENERATOR ◂</p>

	<div class="cabinet">

		<!-- Pixel lights -->
		<div class="pixel-lights">
			<div class="pixel-light"></div>
			<div class="pixel-light"></div>
			<div class="pixel-light"></div>
			<div class="pixel-light"></div>
			<div class="pixel-light"></div>
			<div class="pixel-light"></div>
		</div>

		<!-- Screen -->
		<div class="screen-bezel">
			<div class="screen">
				<div class="reel-edge top"></div>
				<div class="joke-reel">
					<div class="joke-text idle" id="joke-text">PRESS THE BUTTON</div>
				</div>
				<div class="reel-edge bottom"></div>
			</div>
		</div>

		<!-- Status bar -->
		<div class="status-bar">
			<span class="status-label">DADABASE v1.0</span>
			<span class="pull-count" id="pull-count">PRESSES: 000</span>
		</div>

		<!-- Arcade button panel -->
		<div class="button-panel">
			<div class="arcade-btn-wrap" id="arcade-btn" onclick="doPull()">
				<div class="arcade-btn-inner">PRESS</div>
				<p class="btn-label">[ INSERT JOKE ]</p>
			</div>
		</div>

	</div>

	<p class="page-footer">michaelflaugher.com &nbsp;·&nbsp; JOKES BY ICANHAZDADJOKE.COM</p>

	<script is:inline>

		let isSpinning = false;
		let pullCount  = 0;
		let spinInterval = null;

		const CHARS = 'ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789!@#$%?*&░▒▓█▄▀■□▪▫';

		async function doPull() {
			if (isSpinning) return;
			isSpinning = true;

			const jokeEl = document.getElementById('joke-text');
			const btn    = document.getElementById('arcade-btn');

			// Button press animation
			btn.classList.add('pressed');
			setTimeout(() => btn.classList.remove('pressed'), 150);

			// Update counter
			pullCount++;
			document.getElementById('pull-count').textContent =
				'PRESSES: ' + String(pullCount).padStart(3, '0');

			// Scramble screen
			jokeEl.className = 'joke-text spinning';
			jokeEl.textContent = scramble(16);

			let spinSpeed = 60;
			let elapsed   = 0;
			const TOTAL_SPIN = 1800;

			spinInterval = setInterval(() => {
				elapsed += spinSpeed;
				jokeEl.textContent = scramble(Math.floor(8 + (elapsed / TOTAL_SPIN) * 20));
				if (elapsed > TOTAL_SPIN * 0.5)  spinSpeed = 120;
				if (elapsed > TOTAL_SPIN * 0.75) spinSpeed = 200;
				if (elapsed >= TOTAL_SPIN) {
					clearInterval(spinInterval);
					fetchJoke();
				}
			}, spinSpeed);
		}

		function scramble(length) {
			let out = '';
			for (let i = 0; i < length; i++) {
				out += Math.random() > 0.7 ? ' ' : CHARS[Math.floor(Math.random() * CHARS.length)];
			}
			return out;
		}

		async function fetchJoke() {
			const jokeEl = document.getElementById('joke-text');
			try {
				const res  = await fetch('https://icanhazdadjoke.com/', { headers: { 'Accept': 'application/json' } });
				const data = await res.json();
				jokeEl.className   = 'joke-text result';
				jokeEl.textContent = data.joke;
				setTimeout(() => { jokeEl.className = 'joke-text'; }, 400);
			} catch (err) {
				jokeEl.className   = 'joke-text';
				jokeEl.textContent = 'ERROR: DAD JOKES UNAVAILABLE. CHECK YOUR WI-FI, SON.';
			}
			isSpinning = false;
		}

	</script>

</body>
</html>
